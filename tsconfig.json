{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "declaration": true,
        "emitDeclarationOnly": false,
        "strict": true,
        "useDefineForClassFields": false,
        "experimentalDecorators": false,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true
    },
    "include": ["src"]
}
