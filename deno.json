{
    "tasks": {
        "check": "deno lint && pnpm run check"
    },
    "nodeModulesDir": "manual",
    "lock": false,
    "exclude": ["dist", "node_modules"],
    "lint": {
        "exclude": ["tests"]
    },
    "fmt": {
        "exclude": ["pnpm-lock.yaml", "dist", "docs"],
        "indentWidth": 4,
        "lineWidth": 100,
        "trailingCommas": "onlyMultiLine",
        "operatorPosition": "nextLine"
    },
    "compilerOptions": {
        "lib": ["dom", "dom.iterable", "esnext"],
        "strict": true
    }
}
